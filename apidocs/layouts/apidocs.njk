<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <title>{{ title or "apidocs" }}</title>
    <link rel="stylesheet" href="{{ apidocs.assets.css }}">
    <script type="speculationrules">
      {
        "prefetch": [{
          "source": "document",
          "where": { "href_matches": "/*" },
          "eagerness": "moderate"
        }]
      }
    </script>
    <script>
      // symbols.json URL. In prod this is a placeholder substituted per page
      // post-build (relativized + content-hashed once symbols are known); in
      // dev the shell injects a stable absolute URL directly. See
      // eleventy.after in apidocs/index.js.
      window.__APIDOCS_SYMBOLS_URL__ = "{{ apidocs.assets.symbolsUrl }}";

      // Ordered list of data-api-kind values that sort to the front of the
      // API search group (relevance order within each kind, then any
      // unlisted kinds). Empty by default — see the apiKindOrder option.
      window.__APIDOCS_API_KIND_ORDER__ = {{ apidocs.apiKindOrder | dump | safe }};

      // Per-group search result caps (reserved api/sections/pages keys) plus
      // per-data-api-kind sub-caps, and the fuzzysort retrieval count. Both
      // default to the previously hard-coded values — see the searchLimits and
      // searchFetchLimit options.
      window.__APIDOCS_SEARCH_LIMITS__ = {{ apidocs.searchLimits | dump | safe }};
      window.__APIDOCS_SEARCH_FETCH_LIMIT__ = {{ apidocs.searchFetchLimit | dump | safe }};
    </script>
    <script>
      // FOUC-prevention: apply the persisted theme before paint.
      (function () {
        try {
          var saved = localStorage.getItem("apidocs-theme");
          if (saved === "light" || saved === "dark") {
            document.documentElement.setAttribute("data-theme", saved);
          }
        } catch (e) { /* private mode etc. */ }
      })();
    </script>
    <script>
      // Preserve the main-nav scroll offset across navigation. Inline in <head>
      // — not in the deferred bundle — so the `pagereveal` listener is attached
      // before the new document's first render, which a deferred module can miss.
      (function () {
        var KEY = "apidocs-nav-scroll";
        var scroller = function () {
          return document.querySelector(".main-nav > ul");
        };
        var save = function () {
          var el = scroller();
          if (el) {
            try { sessionStorage.setItem(KEY, String(el.scrollTop)); } catch (e) { /* private mode etc. */ }
          }
        };
        var restore = function () {
          var el = scroller();
          var y = null;
          try { y = sessionStorage.getItem(KEY); } catch (e) { /* private mode etc. */ }
          if (el && y !== null) {
            el.scrollTop = Number(y);
          }
        };

        if ("onpagereveal" in window) {
          window.addEventListener("pageswap", save);
          window.addEventListener("pagereveal", restore);
        } else {
          window.addEventListener("pagehide", save);
          window.addEventListener("DOMContentLoaded", restore);
        }
      })();
    </script>
    {% if apidocs.dev %}
    <script>
      // Dev-only: the dev server re-syncs <html>'s attributes to the freshly
      // served markup on each hot update, stripping the runtime data-theme; a
      // DOM delta isn't a navigation, so the FOUC script above never re-runs.
      // Re-apply from storage whenever the attribute disappears.
      (function () {
        var html = document.documentElement;
        new MutationObserver(function () {
          if (!html.hasAttribute("data-theme")) {
            try {
              var saved = localStorage.getItem("apidocs-theme");
              if (saved === "light" || saved === "dark") {
                html.setAttribute("data-theme", saved);
              }
            } catch (e) { /* private mode etc. */ }
          }
        }).observe(html, { attributes: true, attributeFilter: ["data-theme"] });
      })();
    </script>
    {% endif %}
    {{ apidocs.head | safe }}
  </head>
  <body>
    <div class="layout">
      <header class="site-header">
        <button type="button" class="nav-toggle" data-nav-toggle
                aria-expanded="false" aria-controls="main-nav"
                aria-label="Open navigation">
          <svg class="nav-toggle-open" viewBox="0 0 24 24" width="20" height="20"
               aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6"  x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
          <svg class="nav-toggle-close" viewBox="0 0 24 24" width="20" height="20"
               aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round">
            <line x1="5"  y1="5"  x2="19" y2="19"></line>
            <line x1="19" y1="5"  x2="5"  y2="19"></line>
          </svg>
        </button>
        <div class="logo">{{ apidocs.logo | safe }}</div>
        <div class="search">{% include "search.njk" ignore missing %}</div>
        <div class="theme-switch">{% include "theme-switch.njk" ignore missing %}</div>
      </header>
      <div class="layout-body">
        <nav class="main-nav" id="main-nav">{% include "navigation.njk" ignore missing %}</nav>
        <main class="article" data-pagefind-body>
          {{ content | safe }}
          {% include "prev-next.njk" ignore missing %}
        </main>
        <nav class="toc">{% include "toc.njk" ignore missing %}</nav>
      </div>
      <footer class="site-footer">{{ apidocs.footer | safe }}</footer>
    </div>
    <script type="module" src="{{ apidocs.assets.js }}"></script>
  </body>
</html>
