{# Prev/next article links rendered at the end of each article. `prev` and
   `next` are computed in index.js from the flat navigation order; both can
   be null at the ends of the manifest. data-pagefind-ignore keeps the
   labels out of the prose search index. #}
{% if prev or next %}
<nav class="prev-next" data-pagefind-ignore aria-label="Article navigation">
  {% if prev %}
  <a class="prev-next-link prev-next-prev" href="/{{ prev.slug }}{{ '/' if prev.slug else '' }}" rel="prev">
    <span class="prev-next-direction">Previous</span>
    <span class="prev-next-title">{{ prev.title }}</span>
  </a>
  {% endif %}
  {% if next %}
  <a class="prev-next-link prev-next-next" href="/{{ next.slug }}{{ '/' if next.slug else '' }}" rel="next">
    <span class="prev-next-direction">Next</span>
    <span class="prev-next-title">{{ next.title }}</span>
  </a>
  {% endif %}
</nav>
{% endif %}
