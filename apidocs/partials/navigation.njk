{# Main navigation. Article entries are normalized to {slug, title} by
   lib/load-navigation.js before reaching this partial, so it only ever
   sees objects. The manifest itself accepts these shapes:

   Flat:      [ "slug" | {slug, title}, ... ]
   Chaptered: { chapters: [ {title, articles: [ "slug" | {slug, title}, ... ]}, ... ] }

   Bare strings have their title pulled from the target page's <h1>.

   A chapter may also carry an optional "section" string: a divider label
   rendered above it that groups the chapters that follow until the next
   chapter with its own "section". It is a flat marker, not a nesting level.

   An article with `expand` in the manifest gets a `children` array
   ({slug, anchor, title}) of the target page's top-level sections, attached
   by the loader. They render as sibling links right after the article — at
   the same level as ordinary pages, not as a deeper nesting — so an expanded
   page reads like a chapter whose "pages" are its sections.

   The current page is marked .active by comparing page.url against the
   entry's "/slug/" path. #}

{% set nav = apidocs.navigation %}
{% set currentUrl = page.url %}

{% macro articleLink(article) %}
  {%- set href = "/" + article.slug + ("/" if article.slug else "") -%}
  {%- set isActive = currentUrl == href -%}
  <li{% if isActive %} class="active"{% endif %}>
    <a href="{{ href }}">{{ article.title }}</a>
  </li>
  {%- if article.children %}
  {% for child in article.children %}
  <li><a href="/{{ child.slug }}/#{{ child.anchor }}">{{ child.title }}</a></li>
  {% endfor %}
  {%- endif %}
{% endmacro %}

{% if nav.chapters %}
<ul class="chapters">
  {% for chapter in nav.chapters %}
  {% if chapter.section %}<li class="chapter-section" aria-hidden="true">{{ chapter.section }}</li>{% endif %}
  <li class="chapter">
    {% if chapter.title %}<h3 class="chapter-title">{{ chapter.title }}</h3>{% endif %}
    <ul class="articles">
      {% for article in chapter.articles %}{{ articleLink(article) }}{% endfor %}
    </ul>
  </li>
  {% endfor %}
</ul>
{% elif nav %}
<ul class="articles">
  {% for article in nav %}{{ articleLink(article) }}{% endfor %}
</ul>
{% endif %}
