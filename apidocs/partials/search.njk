{# Header search. The trigger opens a <dialog> hosting Pagefind UI.
   The UI bundle (pagefind-ui.js + .css) is loaded by the layout from
   /pagefind/, which the postbuild indexer emits. #}
<button type="button" class="search-trigger" data-search-open
        aria-label="Open search" aria-haspopup="dialog">
  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"
       fill="none" stroke="currentColor" stroke-width="2"
       stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="7"></circle>
    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
  </svg>
  <span class="search-trigger-label">Search</span>
  <kbd class="search-trigger-kbd">/</kbd>
</button>
<dialog class="search-dialog" data-search-dialog aria-label="Search">
  <div class="search-ui" data-search-ui></div>
</dialog>
