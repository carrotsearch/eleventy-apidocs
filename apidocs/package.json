{
  "name": "@carrotsearch/eleventy-apidocs",
  "version": "0.1.4",
  "description": "Eleventy plugin for HTML-source product documentation",
  "keywords": [
    "eleventy",
    "eleventy-plugin",
    "documentation",
    "api-docs",
    "static-site",
    "html",
    "pagefind",
    "shiki"
  ],
  "homepage": "https://github.com/carrotsearch/eleventy-apidocs#readme",
  "bugs": "https://github.com/carrotsearch/eleventy-apidocs/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carrotsearch/eleventy-apidocs.git",
    "directory": "apidocs"
  },
  "license": "MIT",
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./layouts/*": "./layouts/*",
    "./partials/*": "./partials/*",
    "./assets/*": "./assets/*",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "lib/",
    "layouts/",
    "partials/",
    "styles/",
    "assets/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test 'test/*.test.js'"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "peerDependencies": {
    "@11ty/eleventy": ">=3.0.0"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "cheerio": "^1.2.0",
    "esbuild": "^0.28.0",
    "fuzzysort": "^3.1.0",
    "jsonc-parser": "^3.3.1",
    "jsonpath-plus": "^10.4.0",
    "lightningcss": "^1.32.0",
    "nunjucks": "^3.2.4",
    "pagefind": "^1.5.2",
    "shiki": "^4.1.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
