{
  "name": "@carrotsearch/eleventy-apidocs",
  "version": "0.1.0",
  "description": "Eleventy plugin for HTML-source product documentation",
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./layouts/*": "./layouts/*",
    "./partials/*": "./partials/*",
    "./assets/*": "./assets/*",
